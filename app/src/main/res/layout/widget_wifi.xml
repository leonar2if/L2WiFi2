<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:weightSum="2"
    android:padding="16dp"
    android:background="@drawable/widget_round_background">

    <!-- PARTE SUPERIOR (2x1) - Pantalla de Información -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.1"
        android:padding="8dp">

        <ViewFlipper
            android:id="@+id/view_flipper_top"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Estado 0: Nombre de la Cuenta Activa -->
            <TextView
                android:id="@+id/txt_username"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Sin Cuentas"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Estado 1: Mensajes de Estado Dinámicos (hh:mm:ss, Conectando..., ¡Error!) -->
            <TextView
                android:id="@+id/txt_status_msg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Conectando..."
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
        </ViewFlipper>
    </FrameLayout>

    <!-- PARTE INFERIOR - Dos Botones 1x1 Completamente Redondos -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.9"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="2">

        <ImageButton
            android:id="@+id/btn_left"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/btn_circular_bg"
            android:src="@android:drawable/ic_menu_compass"
            android:tint="#2A62CC"
            android:contentDescription="Acción Izquierda" />

        <ImageButton
            android:id="@+id/btn_right"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginStart="14dp"
            android:background="@drawable/btn_circular_bg"
            android:src="@android:drawable/ic_menu_agenda"
            android:tint="#2A62CC"
            android:contentDescription="Acción Derecha" />
    </LinearLayout>
</LinearLayout>


